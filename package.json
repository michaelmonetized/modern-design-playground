{
	"name": "modern-design-playground",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "dotenv -e .env.local -- sh -c \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000\"",
		"generate-routes": "tsr generate",
		"build": "vite build && cp instrument.server.mjs .output/server",
		"preview": "vite preview",
		"test": "vitest run",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint",
		"typecheck": "tsgo --noEmit",
		"check": "oxfmt --check && oxlint && tsgo --noEmit",
		"start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
		"marathon:iterate": "node scripts/iterate-loop.mjs",
		"marathon:smoke": "node scripts/smoke-interact.mjs",
		"marathon:forever": "node scripts/marathon-forever.mjs"
	},
	"dependencies": {
